<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Locatic</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Locatic.styles.css" asp-append-version="true" />
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital@1&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet" />
    
    <style>
        * { font-family: 'Inter', sans-serif; }

        body {
            background-color: #0a0a0a;
            color: #e8e8e8;
        }

        .navbar {
            background-color: #0a0a0a !important;
            border-bottom: 1px solid #1a2a1a !important;
            padding: 1rem 1.5rem;
        }

        .navbar-brand {
            color: #4ade80 !important;
            font-family: 'Playfair Display', serif;
            font-style: italic;
            font-size: 1.8rem;
            font-weight: 400;
            letter-spacing: 0.05em;
        }

        .nav-link {
            color: #6b7280 !important;
            font-size: 0.85rem;
            font-weight: 400;
            letter-spacing: 0.03em;
            padding: 0.5rem 1rem !important;
            transition: color 0.2s;
        }

        .nav-link:hover {
            color: #4ade80 !important;
        }

        h2 {
            color: #f9fafb;
            font-weight: 500;
            font-size: 1.5rem;
            margin-bottom: 1.5rem;
            letter-spacing: -0.01em;
        }

        .table {
            color: #d1d5db;
            border-color: #1f2937;
        }

        .table thead th {
            background-color: #111827;
            color: #4ade80;
            font-size: 0.7rem;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.1em;
            border-color: #1f2937;
            padding: 1rem;
        }

        .table tbody tr {
            border-color: #1a1a1a;
            transition: background-color 0.15s;
        }

        .table tbody tr:hover {
            background-color: #111111;
        }

        .table td {
            border-color: #1a1a1a;
            padding: 0.875rem 1rem;
            vertical-align: middle;
            font-size: 0.9rem;
        }

        .btn-primary {
            background-color: #166534;
            border: 1px solid #166534;
            color: #4ade80;
            font-size: 0.85rem;
            font-weight: 500;
            padding: 0.5rem 1.25rem;
            border-radius: 6px;
            transition: all 0.2s;
        }

        .btn-primary:hover {
            background-color: #15803d;
            border-color: #15803d;
            color: #bbf7d0;
        }

        .btn-warning {
            background-color: transparent;
            border: 1px solid #854d0e;
            color: #fbbf24;
            font-size: 0.8rem;
            padding: 0.3rem 0.75rem;
            border-radius: 5px;
        }

        .btn-warning:hover {
            background-color: #854d0e;
            color: #fef9c3;
        }

        .btn-danger {
            background-color: transparent;
            border: 1px solid #7f1d1d;
            color: #f87171;
            font-size: 0.8rem;
            padding: 0.3rem 0.75rem;
            border-radius: 5px;
        }

        .btn-danger:hover {
            background-color: #7f1d1d;
            color: #fecaca;
        }

        .btn-info {
            background-color: transparent;
            border: 1px solid #1e3a5f;
            color: #60a5fa;
            font-size: 0.8rem;
            padding: 0.3rem 0.75rem;
            border-radius: 5px;
        }

        .btn-info:hover {
            background-color: #1e3a5f;
            color: #bfdbfe;
        }

        .btn-secondary {
            background-color: transparent;
            border: 1px solid #374151;
            color: #9ca3af;
            font-size: 0.85rem;
            padding: 0.5rem 1.25rem;
            border-radius: 6px;
        }

        .btn-secondary:hover {
            background-color: #1f2937;
            color: #e5e7eb;
        }

        .form-control, .form-select {
            background-color: #111111;
            border: 1px solid #1f2937;
            color: #e8e8e8;
            border-radius: 6px;
            font-size: 0.9rem;
        }

        .form-control:focus, .form-select:focus {
            background-color: #111111;
            border-color: #4ade80;
            color: #e8e8e8;
            box-shadow: 0 0 0 3px rgba(74, 222, 128, 0.1);
        }

        .form-label {
            color: #9ca3af;
            font-size: 0.8rem;
            font-weight: 500;
            text-transform: uppercase;
            letter-spacing: 0.05em;
            margin-bottom: 0.4rem;
        }

        .form-select option {
            background-color: #111111;
            color: #e8e8e8;
        }

        .text-danger { color: #f87171 !important; }
        .text-muted { color: #6b7280 !important; }

        .container main { padding-top: 2rem; }

        dl.row dt { color: #6b7280; font-size: 0.85rem; }
        dl.row dd { color: #e8e8e8; }

        footer {
            margin-top: 4rem;
            padding: 1.5rem 0;
            border-top: 1px solid #1a1a1a !important;
            text-align: center;
        }

        footer span { color: #374151; font-size: 0.8rem; }
    </style>
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm border-bottom mb-3">
            <div class="container-fluid">
                <a class="navbar-brand" asp-controller="Home" asp-action="Index">LOCATIC</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="Index">Home</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Brands" asp-action="Index">Brands</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="CarModels" asp-action="Index">Car Models</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Cars" asp-action="Index">Cars</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Customers" asp-action="Index">Customers</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Bookings" asp-action="Index">Bookings</a>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>
    <footer>
        <span>© 2026 Locatic</span>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>