@model IEnumerable<Locatic.Models.Booking>

<h1>Bookings</h1>

<a asp-action="Create" class="btn btn-primary">Add Booking</a>

<table class="table mt-3">
    <thead>
        <tr>
            <th>Customer</th>
            <th>Car</th>
            <th>Model</th>
            <th>Brand</th>
            <th>Start Date</th>
            <th>End Date</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var booking in Model)
        {
            <tr>
                <td>@booking.Customer.FirstName @booking.Customer.LastName</td>
                <td>@booking.Car.LicensePlate</td>
                <td>@booking.Car.CarModel.Name</td>
                <td>@booking.Car.CarModel.Brand.Name</td>
                <td>@booking.StartDate.ToString("dd/MM/yyyy")</td>
                <td>@booking.EndDate.ToString("dd/MM/yyyy")</td>
            </tr>
        }
    </tbody>
</table>