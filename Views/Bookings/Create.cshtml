@model Locatic.Models.Booking

<h1>Ajouter une réservation</h1>

<form asp-action="Create" method="post">

    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <div class="mb-3">
        <label asp-for="CustomerId" class="form-label">Client</label>
        <select asp-for="CustomerId" asp-items="ViewBag.Customers" class="form-control">
            <option value="">-- Choisir un client --</option>
        </select>
        <span asp-validation-for="CustomerId" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="CarId" class="form-label">Voiture</label>
        <select asp-for="CarId" asp-items="ViewBag.Cars" class="form-control">
            <option value="">-- Choisir une voiture --</option>
        </select>
        <span asp-validation-for="CarId" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="StartDate" class="form-label">Date de début</label>
        <input asp-for="StartDate" type="date" class="form-control" />
        <span asp-validation-for="StartDate" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="EndDate" class="form-label">Date de fin</label>
        <input asp-for="EndDate" type="date" class="form-control" />
        <span asp-validation-for="EndDate" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-success">Enregistrer</button>
    <a asp-action="Index" class="btn btn-secondary">Retour</a>
</form>